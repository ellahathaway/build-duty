{
  "mcpServers": {
    "build-duty-mcp-server": {
      "type": "local",
      "command": "dotnet",
      "args": ["run", "--project", "../../../src/BuildDuty.Mcp/BuildDuty.Mcp.csproj"],
      "env": {},
      "tools": ["*"]
    },
    "azure-devops-mcp-server": {
      "type": "http",
      "url": "https://mcp.dev.azure.com/",
      "tools": ["*"]
    },
    "github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "tools": ["*"]
    }
  }
}
